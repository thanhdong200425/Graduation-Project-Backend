PORT=3344

# CORS — Vite dev server; comma-separated for multiple origins
CORS_ORIGIN=http://localhost:5173

# POSTGRES
DB_PORT=5432
DB_NAME=graduation_project_db
DB_USER=postgres
DB_PASSWORD=postgres
CONTAINER_NAME=graduation_project_postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/graduation_project_db"

# QDRANT
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=replace-me
QDRANT_COLLECTION=textbook_chunks

# LLM — OLLAMA (local) or API (Gemini via @langchain/google-genai)
MODEL_TYPE=OLLAMA
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=

# OLLAMA
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=all-minilm
OLLAMA_TEMPERATURE=0.2
USE_EMBEDDING_FROM_OLLAMA=true

# MONGODB
MONGO_PORT=27017
MONGO_CONTAINER_NAME=graduation_project_mongodb
MONGO_INITDB_ROOT_USERNAME=mongo
MONGO_INITDB_ROOT_PASSWORD=mongo
MONGO_INITDB_DATABASE=graduation_project_mongodb

# AUTH
JWT_SECRET="replace-me"
JWT_EXPIRES_IN="1d"

# FRONTEND
FRONTEND_URL=http://localhost:5173

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-password
SMTP_FROM=your-email@gmail.com

# Google OAuth (redirect-based sign-in). Leave CLIENT_ID/SECRET blank to disable.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3344/auth/google/callback