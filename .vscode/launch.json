{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug NestJS (testmaker-backend)",
      "runtimeExecutable": "yarn",
      "runtimeArgs": [
        "start:debug"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "restart": true,
      "autoAttachChildProcesses": true
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to NestJS (testmaker-backend)",
      "port": 9229,
      "restart": true
    }
  ]
}