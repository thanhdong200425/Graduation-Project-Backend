generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String
  role         UserRole    @default(TEACHER)
  status       UserStatus  @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  pdfUploads   PdfUpload[]
  
  teacherSessions    ExamSession[] @relation("TeacherSessions")
  studentSubmissions Submission[]  @relation("StudentSubmissions")
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PdfUpload {
  id           String          @id @default(uuid())
  uploadedById String
  chapterId    String?
  fileName     String
  fileHash     String          @unique
  filePath     String
  status       PdfUploadStatus @default(PENDING)
  progress     Int             @default(0)
  currentStep  CurrentStep     @default(PARSING)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  uploadedBy   User            @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  chapter      Chapter?        @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([uploadedById])
  @@index([chapterId])
  @@map("pdf_uploads")
}

model Subject {
  id          String    @id @default(uuid())
  name        String
  grade       Int
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  chapters    Chapter[]
  exams       Exam[]

  @@map("subjects")
}

model Chapter {
  id             String          @id @default(uuid())
  subjectId      String
  name           String
  description    String?
  orderIndex     Int?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  subject        Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  exams          Exam[]
  questions      Question[]
  textbookChunks TextbookChunk[]
  pdfUploads     PdfUpload[]

  @@index([subjectId])
  @@map("chapters")
}

model TextbookChunk {
  id        String     @id @default(uuid())
  chapterId String
  lesson    String?
  topic     String?
  content   String
  keywords  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  questions Question[]
  chapter   Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@map("textbook_chunks")
}

model Question {
  /// Question bank item (usually AI-generated, then reviewed).
  ///
  /// Purpose:
  /// - Stores the canonical MCQ content (stem + 4 options + correct answer).
  /// - Tracks moderation/review state via `status` (DRAFT/APPROVED/REJECTED).
  /// - Can be reused across many exams via `ExamQuestion` (many-to-many).
  ///
  /// Provenance:
  /// - `chapterId`/`chunkId` are optional to allow manual/imported questions
  ///   or questions not tied to a specific chunk.
  ///
  /// Example (conceptual):
  /// - A generated question starts as `DRAFT`, then an admin approves it.
  id            String          @id @default(uuid())
  chapterId     String?
  chunkId       String?
  name          String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String
  difficulty    DifficultyLevel
  source        String?
  status        QuestionStatus  @default(DRAFT)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  examItems     ExamItem[]
  chapter       Chapter?        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  chunk         TextbookChunk?  @relation(fields: [chunkId], references: [id])
  explanation   String?
  answerDetails AnswerDetail[]

  @@index([chapterId])
  @@index([chunkId])
  @@index([status])
  @@map("questions")
}

model Exam {
  /// Exam container / blueprint saved by users.
  ///
  /// Purpose:
  /// - Represents an exam a user created/saved (title + scope).
  /// - Stores the intended composition (`totalQuestions` + difficulty mix).
  /// - The actual selected questions live in `ExamQuestion`.
  ///
  /// Example (conceptual):
  /// - title="Chapter 1 - Practice", totalQuestions=20,
  ///   difficultyEasy=5, difficultyMedium=10, difficultyHard=5.
  id               String     @id @default(uuid())
  subjectId        String?
  chapterId        String?
  title            String
  totalQuestions   Int
  difficultyEasy   Int
  difficultyMedium Int
  difficultyHard   Int
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  examItems        ExamItem[]
  chapter          Chapter?   @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  subject          Subject?   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  sessions         ExamSession[]

  @@index([subjectId])
  @@index([chapterId])
  @@map("exams")
}

model ExamItem {
  /// Join table linking `Exam` <-> `Question` with ordering.
  ///
  /// Purpose:
  /// - Each row means: "this exam includes this question".
  /// - `orderIndex` keeps a stable question order (Q1, Q2, ...).
  /// - `@@unique([examId, questionId])` prevents duplicates in the same exam.
  ///
  /// Example (conceptual):
  /// - examId=E1, questionId=Q1, orderIndex=1
  /// - examId=E1, questionId=Q2, orderIndex=2
  id         String   @id @default(uuid())
  examId     String
  questionId String
  orderIndex Int
  createdAt  DateTime @default(now())
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([examId, questionId])
  @@index([examId])
  @@index([questionId])
  @@map("exam_items")
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum QuestionStatus {
  DRAFT
  APPROVED
  REJECTED
}

enum PdfUploadStatus {
  PENDING
  INDEXED
  FAILED
}

enum CurrentStep {
  PARSING
  CHUNKING
  EMBEDDING
  STORING
  DONE
}

model GenerationJob {
  id        String           @id @default(uuid())
  status    GenerationStatus @default(PENDING)
  progress  Int              @default(0)
  result    Json?
  error     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("generation_jobs")
}

enum GenerationStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

// Represents a published, live instance of a generated exam
model ExamSession {
  id            String            @id @default(uuid())
  examId        String            // FK to the existing Exam model in TestMaker
  teacherId     String            // FK to User (teacher role)
  inviteCode    String            @unique  // e.g. "EXAM-4821"
  publicLink    String            @unique  // e.g. "/join/abc123xyz"
  timeLimitMins Int?              // null = untimed
  showAnswers   Boolean           @default(false) // teacher toggles this
  status        ExamSessionStatus @default(DRAFT)
  startsAt      DateTime?         // optional scheduled start
  endsAt        DateTime?         // optional scheduled end
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  teacher     User         @relation("TeacherSessions", fields: [teacherId], references: [id])
  exam        Exam         @relation(fields: [examId], references: [id])
  submissions Submission[]

  @@map("exam_sessions")
}

enum ExamSessionStatus {
  DRAFT    // created but not yet open
  ACTIVE   // students can join and submit
  CLOSED   // teacher manually closed; no new submissions
}

// One submission = one student's completed attempt at a session
model Submission {
  id             String    @id @default(uuid())
  sessionId      String
  studentId      String    // FK to User (student role)
  startedAt      DateTime  @default(now())
  submittedAt    DateTime?
  isAutoSubmit   Boolean   @default(false) // true if timer ran out
  score          Float?    // 0–10
  totalCorrect   Int?
  totalQuestions Int

  session       ExamSession    @relation(fields: [sessionId], references: [id])
  student       User           @relation("StudentSubmissions", fields: [studentId], references: [id])
  answerDetails AnswerDetail[]

  @@unique([sessionId, studentId]) // one attempt per student per session
  @@map("submissions")
}

// Stores the student's answer to each individual question
model AnswerDetail {
  id             String  @id @default(uuid())
  submissionId   String
  questionId     String  // FK to Question model
  selectedOption Int     // 0-indexed: which option the student picked
  isCorrect      Boolean

  submission Submission @relation(fields: [submissionId], references: [id])
  question   Question   @relation(fields: [questionId], references: [id])

  @@map("answer_details")
}
