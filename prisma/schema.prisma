generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  pdfUploads   PdfUpload[]
}

model PdfUpload {
  id           String          @id @default(uuid())
  uploadedById String
  chapterId    String?
  fileName     String
  fileHash     String          @unique
  filePath     String
  status       PdfUploadStatus @default(PENDING)
  progress     Int             @default(0)
  currentStep  CurrentStep     @default(PARSING)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  uploadedBy   User            @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  chapter      Chapter?        @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([uploadedById])
  @@index([chapterId])
  @@map("pdf_uploads")
}

model Subject {
  id          String    @id @default(uuid())
  name        String
  grade       Int
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  chapters    Chapter[]
  exams       Exam[]

  @@map("subjects")
}

model Chapter {
  id                 String              @id @default(uuid())
  subjectId          String
  name               String
  description        String?
  orderIndex         Int?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  subject            Subject             @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  exams              Exam[]
  generatedQuestions GeneratedQuestion[]
  textbookChunks     TextbookChunk[]
  pdfUploads         PdfUpload[]

  @@index([subjectId])
  @@map("chapters")
}

model TextbookChunk {
  id                 String              @id @default(uuid())
  chapterId          String
  lesson             String?
  topic              String?
  content            String
  keywords           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  generatedQuestions GeneratedQuestion[]
  chapter            Chapter             @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@map("textbook_chunks")
}

model GeneratedQuestion {
  id            String          @id @default(uuid())
  chapterId     String?
  chunkId       String?
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String
  difficulty    DifficultyLevel
  source        String?
  status        QuestionStatus  @default(DRAFT)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  examQuestions ExamQuestion[]
  chapter       Chapter?        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  chunk         TextbookChunk?  @relation(fields: [chunkId], references: [id])

  @@index([chapterId])
  @@index([chunkId])
  @@index([status])
  @@map("generated_questions")
}

model Exam {
  id               String         @id @default(uuid())
  subjectId        String?
  chapterId        String?
  title            String
  totalQuestions   Int
  difficultyEasy   Int
  difficultyMedium Int
  difficultyHard   Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  examQuestions    ExamQuestion[]
  chapter          Chapter?       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  subject          Subject?       @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
  @@index([chapterId])
  @@map("exams")
}

model ExamQuestion {
  id         String            @id @default(uuid())
  examId     String
  questionId String
  orderIndex Int
  createdAt  DateTime          @default(now())
  exam       Exam              @relation(fields: [examId], references: [id], onDelete: Cascade)
  question   GeneratedQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([examId, questionId])
  @@index([examId])
  @@index([questionId])
  @@map("exam_questions")
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum QuestionStatus {
  DRAFT
  APPROVED
  REJECTED
}

enum PdfUploadStatus {
  PENDING
  INDEXED
  FAILED
}

enum CurrentStep {
  PARSING
  CHUNKING
  EMBEDDING
  STORING
  DONE
}

model GenerationJob {
  id        String           @id @default(uuid())
  status    GenerationStatus @default(PENDING)
  progress  Int              @default(0)
  result    Json?
  error     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("generation_jobs")
}

enum GenerationStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}
